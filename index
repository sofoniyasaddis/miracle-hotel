        function sendChatMessage() {
            const roomNum = parseInt(document.getElementById('chat-room-num').value);
            const msg = document.getElementById('chat-input').value;
            if(!roomNum || !msg || roomNum < 1 || roomNum > 30) { alert('Verify Room Number configuration.'); return; }

            database.ref('requests/messages').push({ room: roomNum, detail: `[LIVE CHAT] ${msg}`, time: getSimulatedTimestamp() });
            document.getElementById('chat-input').value = '';
        }

        function triggerEmergency() {
            const roomNum = parseInt(document.getElementById('emergency-room-num').value);
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Verification index needed.'); return; }

            database.ref('requests/messages').push({ room: roomNum, detail: `⚠️ EMERGENCY DISTRESS ESCALATION INITIATED!`, urgent: true, time: getSimulatedTimestamp() });
            alert('🚨 PROTOCOL DEPLOYED.'); closeModal('emergency-modal');
        }

        function submitFeedback() {
            const roomNum = parseInt(document.getElementById('feed-room-num-val').value);
            const stars = document.getElementById('feed-rating').value;
            const text = document.getElementById('feed-comment').value;
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Missing Suite context.'); return; }

            database.ref('requests/messages').push({ room: roomNum, detail: `[FEEDBACK REPORT] Rate: ${stars} | Notes: ${text}`, time: getSimulatedTimestamp() });
            alert('Evaluation logged.'); closeModal('feedback-modal');
            document.getElementById('feed-comment').value = '';
        }


        /* --- DYNAMIC DATA PIPELINES (REAL-TIME LISTENING ENGINE) --- */
        
        function updateSuiteStatusNode(roomNumber, state) {
            const targetCell = document.getElementById(`rm${roomNumber}`);
            if(targetCell) {
                const indicator = targetCell.querySelector('.dot-status');
                indicator.className = `dot-status ${state}`;
                localRoomsState[roomNumber] = state;
                calculateOccupancyIndex();
            }
        }

        function calculateOccupancyIndex() {
            let occupied = 0;
            for(let i = 1; i <= 30; i++) {
                if(localRoomsState[i] === 'occupied' || localRoomsState[i] === 'alert') occupied++;
            }
            document.getElementById('occupancy-rate').innerText = ((occupied / 30) * 100).toFixed(1) + '%';
        }

        function runDynamicSyncEngine() {
            // Live Synchronized Custom Menu Pipeline
            database.ref('custom_menu').on('value', snapshot => {
                const guestMenu = document.getElementById('guest-menu-container');
                // Retain default legacy favorites, append dynamic reception ones safely
                guestMenu.innerHTML = `
                    <div class="food-item-card">
                        <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=200" class="food-img">
                        <div class="food-details">
                            <div class="food-title">Prime Wagyu Beef Burger</div>
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <span class="food-price">1,250 ETB</span>
                                <button class="submit-action" style="width:auto; padding:5px 12px; font-size:0.75rem;" onclick="orderFood('Prime Wagyu Beef Burger', 1250)">Order</button>
                            </div>
                        </div>
                    </div>
                    <div class="food-item-card">
                        <img src="https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=200" class="food-img">
                        <div class="food-details">
                            <div class="food-title">Traditional Habesha Coffee Ceremony</div>
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <span class="food-price">180 ETB</span>
                                <button class="submit-action" style="width:auto; padding:5px 12px; font-size:0.75rem;" onclick="orderFood('Traditional Habesha Coffee', 180)">Order</button>
                            </div>
                        </div>
                    </div>`;
                
                snapshot.forEach(child => {
                    const data = child.val();
                    guestMenu.innerHTML += `
                        <div class="food-item-card">
                            <img src="${data.img}" class="food-img" onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200'">
                            <div class="food-details">
                                <div class="food-title">${data.title}</div>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <span class="food-price">${data.price} ETB</span>
                                    <button class="submit-action" style="width:auto; padding:5px 12px; font-size:0.75rem;" onclick="orderFood('${data.title}', ${data.price})">Order</button>
                                </div>
                            </div>
                        </div>`;
                });
            });

            // Live Dynamic Ad Pipeline
            database.ref('campaign_ad').on('value', snapshot => {
                if(snapshot.exists()) {
                    const data = snapshot.val();
                    document.getElementById('guest-ad-banner').style.backgroundImage = `linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.85)), url('${data.img}')`;
                    document.getElementById('ad-banner-title').innerText = data.title;
                    document.getElementById('ad-banner-desc').innerText = data.desc;
                }
            });

            // Food Requests Feed
            database.ref('requests/food').on('value', snapshot => {
                const list = document.getElementById('feed-food'); list.innerHTML = '';
                snapshot.forEach(child => {
                    const data = child.val(); updateSuiteStatusNode(data.room, 'occupied');
                    list.innerHTML += `<div class="feed-item"><span class="time">${data.time}</span><strong>Rm ${data.room}:</strong> ${data.detail}<br><span style="color:var(--accent)">${data.price} ETB</span><button class="action-done-btn" onclick="terminateCloudTicket('requests/food', '${child.key}', ${data.room})">Serve</button></div>`;
                });
                postCalculatedCountUpdates();
            });

            // Housekeeping Requests Feed
            database.ref('requests/housekeeping').on('value', snapshot => {
                const list = document.getElementById('feed-house'); list.innerHTML = '';
                snapshot.forEach(child => {
                    const data = child.val(); updateSuiteStatusNode(data.room, 'occupied');
                    list.innerHTML += `<div class="feed-item"><span class="time">${data.time}</span><strong>Rm ${data.room}:</strong> ${data.detail}<button class="action-done-btn" onclick="terminateCloudTicket('requests/housekeeping', '${child.key}', ${data.room})">Done</button></div>`;
                });
                postCalculatedCountUpdates();
            });

            // Logistics Feed
            database.ref('requests/logistics').on('value', snapshot => {
                const list = document.getElementById('feed-ops'); list.innerHTML = '';
                snapshot.forEach(child => {
                    const data = child.val(); updateSuiteStatusNode(data.room, 'occupied');
                    list.innerHTML += `<div class="feed-item"><span class="time">${data.time}</span><strong>Rm ${data.room}:</strong> ${data.detail}<button class="action-done-btn" onclick="terminateCloudTicket('requests/logistics', '${child.key}', ${data.room})">Clear</button></div>`;
                });
                postCalculatedCountUpdates();
            });

            // Messages & Critical Communications Feed
            database.ref('requests/messages').on('value', snapshot => {
                const list = document.getElementById('feed-msg'); list.innerHTML = '';
                const chatArea = document.getElementById('chat-box-area'); chatArea.innerHTML = '';
                
                snapshot.forEach(child => {
                    const data = child.val();
                    if(data.urgent) { updateSuiteStatusNode(data.room, 'alert'); } 
                    else { updateSuiteStatusNode(data.room, 'occupied'); }
                    
                    const styleClass = data.urgent ? 'feed-item urgent' : 'feed-item';
                    list.innerHTML += `<div class="${styleClass}"><span class="time">${data.time}</span><strong>Rm ${data.room}:</strong> ${data.detail}<button class="action-done-btn" onclick="terminateCloudTicket('requests/messages', '${child.key}', ${data.room})">Dismiss</button></div>`;
                    
                    if(data.detail.includes("[LIVE CHAT]")) {
                        const cleanMsg = data.detail.replace("[LIVE CHAT]", "");
                        chatArea.innerHTML += `<div class="chat-msg guest"><strong>Room ${data.room}:</strong> ${cleanMsg}</div>`;
                    }
                });
                postCalculatedCountUpdates();
            });

            database.ref('metrics/revenue').on('value', snap => { document.getElementById('mgr-rev').innerText = (snap.val() || 0).toLocaleString() + ' ETB'; });
            database.ref('metrics/orders').on('value', snap => { document.getElementById('mgr-orders').innerText = (snap.val() || 0).toLocaleString(); });
        }

        function terminateCloudTicket(path, key, roomNum) {
            database.ref(`${path}/${key}`).remove().then(() => { updateSuiteStatusNode(roomNum, 'vacant'); });
        }

        function postCalculatedCountUpdates() {
            document.getElementById('count-food').innerText = document.getElementById('feed-food').children.length;
            document.getElementById('count-house').innerText = document.getElementById('feed-house').children.length;
            document.getElementById('count-ops').innerText = document.getElementById('feed-ops').children.length;
            document.getElementById('count-msg').innerText = document.getElementById('feed-msg').children.length;
        }

        /* --- EXECUTIVE ANALYTICS GRAPH GENERATORS --- */
        let chartsInitialized = false;
        function renderCharts() {
            if(chartsInitialized) return;
            chartsInitialized = true;

            const ctxRev = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: ['Mar', 'Apr', 'May (Live)'],
                    datasets: [
                        { label: 'Room Yield (ETB)', data: [840000, 790000, 894000], borderColor: '#d4af37', backgroundColor: 'transparent', tension: 0.2 },
                        { label: 'Concierge Add-ons', data: [160000, 145000, 210000], borderColor: '#f3e5ab', backgroundColor: 'transparent', tension: 0.2 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#fff' } } } }
            });

            const ctxMenu = document.getElementById('menuChart').getContext('2d');
            new Chart(ctxMenu, {
                type: 'doughnut',
                data: {
                    labels: ['Burgers', 'Coffee', 'Local Platters', 'Beverages'],
                    datasets: [{ data: [320, 940, 510, 1200], backgroundColor: ['#d4af37', '#f3e5ab', '#222631', '#171a21'], borderWidth: 0 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#fff' } } } }
            });
        }

        runDynamicSyncEngine();
    </script>
</body>
</html>
