        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();

        // Security Encryption Vectors (Hidden from Plain sight UI context prompts)
        const SEC_HASH_RECEPTION = "reception123";
        const SEC_HASH_MANAGER = "manager123";

        let localRoomsState = {};

        // Generate Perfect Sequential Matrix (1 to 30)
        function initMatrixUILayout() {
            const gridContainer = document.getElementById('reception-matrix-grid');
            gridContainer.innerHTML = '';
