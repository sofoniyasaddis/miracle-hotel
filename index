        }
        initMatrixUILayout();

        function unlockPortal(portalType) {
            const inputVal = document.getElementById(`${portalType}-pass-input`).value;
            const validated = (portalType === 'reception' && inputVal === SEC_HASH_RECEPTION) || 
                              (portalType === 'manager' && inputVal === SEC_HASH_MANAGER);
            if (validated) {
                document.getElementById(`${portalType}-lock`).style.display = 'none';
                document.getElementById(`${portalType}-content`).style.display = portalType === 'reception' ? 'flex' : 'block';
                if (portalType === 'manager') renderCharts();
            } else {
                alert('Access authorization failed.');
            }
        }

        function switchTab(tabId) {
            document.querySelectorAll('.app-window').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.target.classList.add('active');
        }

        function openModal(mId) { document.getElementById(mId).style.display = 'flex'; }
        function closeModal(mId) { document.getElementById(mId).style.display = 'none'; }

        function openRoomValidationModal(requestType) {
            document.getElementById('hidden-request-type').value = requestType;
            document.getElementById('quick-room-num').value = '';
            openModal('quick-room-modal');
        }

        function getSimulatedTimestamp() {
            const d = new Date();
            return d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
        }

        /* --- FIREBASE REAL-TIME CLOUD INTERACTION INJECTIONS --- */

        function submitQuickRoomValidatedRequest() {
            const roomNum = parseInt(document.getElementById('quick-room-num').value);
            const requestName = document.getElementById('hidden-request-type').value;
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Enter valid suite destination (1 - 30).'); return; }
            
            database.ref('requests/housekeeping').push({ room: roomNum, detail: requestName, time: getSimulatedTimestamp() });
            alert('Request uploaded.'); closeModal('quick-room-modal');
        }

        function orderFood(itemName, price) {
            const roomNum = parseInt(document.getElementById('food-room-num').value);
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Enter room destination configuration parameter.'); return; }
            
            database.ref('requests/food').push({ room: roomNum, detail: `1x ${itemName}`, price: price, time: getSimulatedTimestamp() });
            database.ref('metrics/revenue').transaction(c => (c || 0) + price);
            database.ref('metrics/orders').transaction(c => (c || 0) + 1);

            alert(`Order deployed to kitchen for Room ${roomNum}.`); closeModal('menu-modal');
        }

        function triggerAmenityRequest(typeString) {
            const roomNum = parseInt(document.getElementById('amenities-room-num').value);
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Verification check failed.'); return; }

            database.ref('requests/housekeeping').push({ room: roomNum, detail: `Requested: ${typeString}`, time: getSimulatedTimestamp() });
            alert(`Logistics alert broadcasted.`); closeModal('amenities-modal');
        }

        function submitMaintenance() {
            const roomNum = parseInt(document.getElementById('maint-room-num').value);
            const text = document.getElementById('maintenance-text').value;
            if(!roomNum || !text || roomNum < 1 || roomNum > 30) { alert('Review parameters entry data.'); return; }

            database.ref('requests/messages').push({ room: roomNum, detail: `[MAINTENANCE TASK] ${text}`, urgent: true, time: getSimulatedTimestamp() });
            alert('Work order dispatched.'); closeModal('maintenance-modal');
            document.getElementById('maintenance-text').value = '';
        }

        function submitFacility() {
            const roomNum = parseInt(document.getElementById('fac-room-num').value);
            const venue = document.getElementById('fac-type').value;
            if(!roomNum || roomNum < 1 || roomNum > 30) { alert('Invalid Room.'); return; }

            database.ref('requests/logistics').push({ room: roomNum, detail: `Spa Reservation: ${venue}`, time: getSimulatedTimestamp() });
            alert('Booking assigned.'); closeModal('facility-modal');
        }

        // RECEPTION MATRIX ACTION: Add Custom Food Offer
        function receptionAddMenuTarget() {
            const title = document.getElementById('menu-add-title').value;
            const price = parseInt(document.getElementById('menu-add-price').value);
            let imgUrl = document.getElementById('menu-add-img').value.trim();

            if(!title || !price) { alert('Provide menu item name and price parameters.'); return; }
            if(!imgUrl) imgUrl = "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200";

            database.ref('custom_menu').push({ title: title, price: price, img: imgUrl });
            alert(`"${title}" injected live into Guest Suite menus.`);
            
            document.getElementById('menu-add-title').value = '';
            document.getElementById('menu-add-price').value = '';
            document.getElementById('menu-add-img').value = '';
